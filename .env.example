# Required for Atlassian Cloud
ATLASSIAN_BASE_URL="https://example.atlassian.net"
ATLASSIAN_EMAIL="your.email@example.com"
ATLASSIAN_API_TOKEN="replace-me"

# Optional Atlassian defaults
ATLASSIAN_DEFAULT_CONFLUENCE_SPACE=""
ATLASSIAN_DEFAULT_JIRA_PROJECT=""
ATLASSIAN_PAGE_SIZE="25"
ATLASSIAN_MAX_RESULTS="100"

# Optional Azure defaults, used by later phases
AZURE_TENANT_ID=""
AZURE_SUBSCRIPTION_ID=""
AZURE_DEFAULT_LOCATION="uksouth"

# Optional Dataverse / Power Platform defaults, used by later phases
PAC_AUTH_NAME=""
DATAVERSE_ENV_URL="https://example.crm11.dynamics.com"
DATAVERSE_ENV_ID=""
DATAVERSE_DEFAULT_SOLUTION=""

